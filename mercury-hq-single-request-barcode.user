// ==UserScript==
// @name         MercuryHQ - Single Request Barcode
// @namespace    https://ebox86.com/
// @version      0.2.0
// @description  Adds a barcode-assisted delivery request tab to MercuryHQ and prepopulates the Single Request form from Mercury services.
// @author       Evan
// @match        *://*/delivery*
// @grant        GM_xmlhttpRequest
// @grant        GM_addStyle
// @connect      localhost
// @run-at       document-idle
// ==/UserScript==

(function () {
  'use strict';

  const CONFIG = {
    apiBaseUrl: 'http://localhost/WsMercuryWebAPI',
    olcByTicketPath: '/OrderLifeCycle.asmx/OLCGetByTicket',
    debug: true,
    labels: {
      newTab: 'Single Request Barcode',
      modalTitle: 'Scan barcode ticket',
      modalPlaceholder: 'Scan or type ticket number',
    },
    selectors: {
      pageTitle: 'div.css-901oao',
      singleRequestTab: '[data-testid="Single Request-tab"]',
      bulkRequestTab: '[data-testid="Bulk Request-tab"]',
      submitButton: '[data-testid="Submit"]',
      cancelButton: '[data-testid="create-task-cancel"]',
      headerContainer: '[data-testid="headerContainer"]',
      tabRowText: 'Delivery Service Request',
      formInputs: {
        assignment: '[data-testid="web_picker_assignment_deliveryService"]',
        deliveryDate: '[data-testid="deliveryDate"]',
        pickUpDateTime: '[data-testid="pickUpDateTime"]',
        referenceNumber: '[data-testid="referenceNumber"]',
        NoOfItems: '[data-testid="NoOfItems"]',
        totalItemValue: '[data-testid="totalItemValue"]',
        itemDescription: '[data-testid="itemDescription"]',
        recipient_name: '[data-testid="recipient_name"]',
        lastName: '[data-testid="lastName"]',
        phone: '[data-testid="phone"]',
        addressLine1: '[data-testid="addressLine1"]',
        addressLine2: '[data-testid="addressLine2"]',
        city: '[data-testid="city"]',
        state: '[data-testid^="web_picker_state_"]',
        zip: '[data-testid="zip"]',
        country: '[data-testid="web_picker_country_US"]',
        locationType: '[data-testid^="web_picker_locationType_"]',
        locationName: '[data-testid="locationName"]',
        specialDeliveryInstructions: '[data-testid="specialDeliveryInstructions"]',
        undeliverableAction: '[data-testid^="web_picker_undeliverableAction_"]',
      },
    },
  };

  const state = {
    mounted: false,
    activeMode: 'normal',
    lastTicketId: null,
    lastLifecycle: null,
  };

  function log(...args) {
    if (CONFIG.debug) console.log('[MHQ Barcode]', ...args);
  }

  function wait(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function qs(sel, root = document) {
    return root.querySelector(sel);
  }

  function qsa(sel, root = document) {
    return Array.from(root.querySelectorAll(sel));
  }

  function escapeHtml(str) {
    return String(str ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
  }

  GM_addStyle(`
    .mhq-barcode-tab {
      cursor: pointer;
      margin: 5px 0 5px 50px;
      padding-top: 8px;
      padding-bottom: 8px;
      border-bottom: 2px solid transparent;
      user-select: none;
    }
    .mhq-barcode-tab--active {
      border-bottom-color: rgb(22, 65, 88) !important;
    }
    .mhq-barcode-tab__text {
      color: rgb(65, 65, 65);
      font-family: Arial;
      font-size: 16px;
    }
    .mhq-barcode-tab--active .mhq-barcode-tab__text {
      color: rgb(22, 65, 88);
      font-weight: 600;
    }
    .mhq-barcode-banner {
      margin: 8px 0 14px 0;
      padding: 10px 12px;
      border-left: 4px solid rgb(22, 65, 88);
      background: rgb(239, 246, 248);
      color: rgb(65, 65, 65);
      font-family: Arial;
      font-size: 12px;
      line-height: 1.5;
      max-width: 768px;
    }
    .mhq-barcode-tag {
      display: inline-block;
      margin-left: 8px;
      padding: 2px 8px;
      border-radius: 999px;
      border: 1px solid rgb(190, 217, 223);
      background: white;
      font-size: 11px;
      color: rgb(22, 65, 88);
    }
    .mhq-highlight {
      outline: 2px solid #ffb000 !important;
      box-shadow: 0 0 0 3px rgba(255,176,0,.18) !important;
    }
    .mhq-modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 2147483000;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .mhq-modal {
      width: min(560px, calc(100vw - 24px));
      background: white;
      border-radius: 10px;
      box-shadow: 0 12px 32px rgba(0,0,0,.22);
      overflow: hidden;
      font-family: Arial;
    }
    .mhq-modal__header,
    .mhq-modal__footer {
      padding: 14px 16px;
      border-bottom: 1px solid #e7e7e7;
    }
    .mhq-modal__footer {
      border-bottom: 0;
      border-top: 1px solid #e7e7e7;
      display: flex;
      justify-content: flex-end;
      gap: 8px;
    }
    .mhq-modal__body {
      padding: 16px;
    }
    .mhq-modal__input {
      width: 100%;
      box-sizing: border-box;
      font-size: 16px;
      padding: 10px 12px;
      border: 1px solid #cfcfcf;
      border-radius: 6px;
    }
    .mhq-btn {
      appearance: none;
      border: 1px solid #cfcfcf;
      background: #f7f7f7;
      color: #111;
      border-radius: 6px;
      padding: 8px 12px;
      cursor: pointer;
      font-family: Arial;
    }
    .mhq-btn--primary {
      border-color: rgb(22, 65, 88);
      background: rgb(22, 65, 88);
      color: white;
    }
  `);

  function createElement(html) {
    const tpl = document.createElement('template');
    tpl.innerHTML = html.trim();
    return tpl.content.firstElementChild;
  }

  function getInput(fieldKey) {
    const sel = CONFIG.selectors.formInputs[fieldKey];
    return sel ? qs(sel) : null;
  }

  function setNativeValue(el, value) {
    if (!el) return;

    const proto = Object.getPrototypeOf(el);
    const descriptor = Object.getOwnPropertyDescriptor(proto, 'value');
    if (descriptor?.set) descriptor.set.call(el, value);
    else el.value = value;

    el.dispatchEvent(new Event('input', { bubbles: true }));
    el.dispatchEvent(new Event('change', { bubbles: true }));
    el.dispatchEvent(new Event('blur', { bubbles: true }));
  }

  function setSelectByValueOrLabel(el, desired) {
    if (!el || desired == null || desired === '') return false;
    const normalized = String(desired).trim().toLowerCase();
    const match = Array.from(el.options || []).find(opt => {
      return opt.value.trim().toLowerCase() === normalized || opt.text.trim().toLowerCase() === normalized || (opt.label || '').trim().toLowerCase() === normalized;
    });
    if (!match) return false;
    setNativeValue(el, match.value);
    return true;
  }

  function highlight(el, reason = 'Review needed') {
    if (!el) return;
    el.classList.add('mhq-highlight');
    el.title = reason;
  }

  function clearHighlights() {
    qsa('.mhq-highlight').forEach(el => el.classList.remove('mhq-highlight'));
  }

  function ensureBanner() {
    let banner = document.getElementById('mhq-barcode-banner');
    if (banner) return banner;

    const anchor = getInput('referenceNumber')?.closest('.css-1dbjc4n[style]')?.parentElement?.parentElement
      || qs('[data-testid="Single Request-tab"]')?.parentElement?.nextElementSibling
      || qs('[data-testid="referenceNumber"]')?.closest('.css-1dbjc4n')
      || document.body;

    banner = createElement(`
      <div id="mhq-barcode-banner" class="mhq-barcode-banner">
        <strong>Barcode mode:</strong>
        <span class="mhq-barcode-banner__text">Inactive.</span>
      </div>
    `);

    if (anchor?.parentElement) anchor.parentElement.insertBefore(banner, anchor);
    else document.body.prepend(banner);
    return banner;
  }

  function updateBanner(text, tagText = '') {
    const banner = ensureBanner();
    const textEl = banner.querySelector('.mhq-barcode-banner__text');
    textEl.textContent = text;

    let tag = banner.querySelector('.mhq-barcode-tag');
    if (tagText) {
      if (!tag) {
        tag = createElement('<span class="mhq-barcode-tag"></span>');
        banner.appendChild(tag);
      }
      tag.textContent = tagText;
    } else if (tag) {
      tag.remove();
    }
  }

  function getText(node, selector) {
    return node.querySelector(selector)?.textContent?.trim() || '';
  }

  function parseLifecycleXml(xmlText) {
    const parser = new DOMParser();
    const xml = parser.parseFromString(xmlText, 'text/xml');
    const err = xml.querySelector('parsererror');
    if (err) throw new Error('Unable to parse Mercury XML response');

    const statusNodes = Array.from(xml.getElementsByTagNameNS('*', 'OLCStatusMsg'));
    const rows = statusNodes.map(node => ({
      id: getText(node, 'ID'),
      msgDateTime: getText(node, 'MSG_DATETIME'),
      statusText: getText(node, 'STATUS_TEXT'),
      ticketId: getText(node, 'TICKET_ID'),
      empName: getText(node, 'EMP_NAME'),
      statusCdDesc: getText(node, 'STATUS_CD_DESC'),
      indvOrgTypCd: getText(node, 'INDV_ORG_TYP_CD'),
    }));

    return {
      ticketId: rows.find(r => r.ticketId)?.ticketId || '',
      latest: rows[0] || null,
      rows,
    };
  }

  function mercuryPost(url, formBody) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method: 'POST',
        url,
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        data: formBody,
        onload: response => {
          if (response.status >= 200 && response.status < 300) resolve(response.responseText);
          else reject(new Error(`Mercury service returned HTTP ${response.status}`));
        },
        onerror: () => reject(new Error('Network error calling Mercury service')),
        ontimeout: () => reject(new Error('Mercury service timed out')),
      });
    });
  }

  async function fetchLifecycleByTicket(ticketId) {
    const url = `${CONFIG.apiBaseUrl}${CONFIG.olcByTicketPath}`;
    const xmlText = await mercuryPost(url, `TicketID=${encodeURIComponent(ticketId)}`);
    return parseLifecycleXml(xmlText);
  }

  function deriveOrderData(ticketId, lifecycle) {
    const latest = lifecycle.latest || {};
    return {
      referenceNumber: lifecycle.ticketId || ticketId,
      NoOfItems: '1',
      totalItemValue: '',
      itemDescription: latest.statusText || '',
      recipient_name: '',
      lastName: '',
      phone: '',
      addressLine1: '',
      addressLine2: '',
      city: '',
      state: '',
      zip: '',
      country: 'United States',
      locationType: '',
      locationName: '',
      specialDeliveryInstructions: '',
      undeliverableAction: '',
      meta: {
        latestStatus: latest.statusCdDesc || '',
        latestStatusAt: latest.msgDateTime || '',
      },
    };
  }

  function fillField(name, value, reviewReason = '') {
    const el = getInput(name);
    if (!el) {
      log('Missing field selector for', name);
      return null;
    }

    if (el.tagName === 'SELECT') {
      if (value) {
        const ok = setSelectByValueOrLabel(el, value);
        if (!ok) highlight(el, reviewReason || `Could not select ${value}`);
      }
    } else if (el.hasAttribute('readonly')) {
      if (value) setNativeValue(el, value);
      if (reviewReason) highlight(el, reviewReason);
    } else {
      setNativeValue(el, value ?? '');
      if (reviewReason) highlight(el, reviewReason);
    }

    return el;
  }

  function applyOrderData(orderData) {
    clearHighlights();

    fillField('referenceNumber', orderData.referenceNumber, 'Confirm scanned order number');
    fillField('NoOfItems', orderData.NoOfItems, 'Verify item count');
    fillField('totalItemValue', orderData.totalItemValue, 'Enter or verify item value');
    fillField('itemDescription', orderData.itemDescription, 'Verify imported item description');
    fillField('recipient_name', orderData.recipient_name, 'Recipient first name still needs source data or manual entry');
    fillField('lastName', orderData.lastName, 'Recipient last name still needs source data or manual entry');
    fillField('phone', orderData.phone, 'Phone still needs source data or manual entry');
    fillField('addressLine1', orderData.addressLine1, 'Address still needs source data or manual entry');
    fillField('addressLine2', orderData.addressLine2, 'Review apartment or suite if needed');
    fillField('city', orderData.city, 'City still needs source data or manual entry');
    fillField('state', orderData.state, 'State still needs source data or manual entry');
    fillField('zip', orderData.zip, 'Zip still needs source data or manual entry');
    fillField('country', orderData.country, 'Confirm country');
    fillField('locationType', orderData.locationType, 'Select location type');
    fillField('locationName', orderData.locationName, 'Optional business or location name');
    fillField('specialDeliveryInstructions', orderData.specialDeliveryInstructions, 'Review delivery instructions');
    fillField('undeliverableAction', orderData.undeliverableAction, 'Select undeliverable action');

    updateBanner(
      `Loaded ticket ${orderData.referenceNumber}. Review highlighted fields before submitting.`,
      orderData.meta.latestStatus ? `${orderData.meta.latestStatus}${orderData.meta.latestStatusAt ? ` @ ${orderData.meta.latestStatusAt}` : ''}` : 'Imported'
    );
  }

  function activateBarcodeTab() {
    state.activeMode = 'barcode';

    const normalTab = qs(CONFIG.selectors.singleRequestTab);
    const barcodeTab = qs('#mhq-single-request-barcode-tab');

    normalTab && normalTab.style.borderBottomWidth !== undefined && (normalTab.style.borderBottomWidth = '0px');
    normalTab && normalTab.querySelector('.css-901oao') && (normalTab.querySelector('.css-901oao').style.color = 'rgb(65, 65, 65)');
    barcodeTab?.classList.add('mhq-barcode-tab--active');

    updateBanner('Barcode mode active. Scan a ticket to prefill the request form.');
    showScanModal();
  }

  function activateNormalTab() {
    state.activeMode = 'normal';
    const normalTab = qs(CONFIG.selectors.singleRequestTab);
    const barcodeTab = qs('#mhq-single-request-barcode-tab');

    if (normalTab) {
      normalTab.style.borderBottomWidth = '2px';
      normalTab.style.borderBottomColor = 'rgb(22, 65, 88)';
      const text = normalTab.querySelector('.css-901oao');
      if (text) text.style.color = 'rgb(22, 65, 88)';
    }
    barcodeTab?.classList.remove('mhq-barcode-tab--active');
    updateBanner('Normal Single Request mode active.');
  }

  function showScanModal() {
    const backdrop = createElement(`
      <div class="mhq-modal-backdrop" role="dialog" aria-modal="true">
        <div class="mhq-modal">
          <div class="mhq-modal__header"><strong>${escapeHtml(CONFIG.labels.modalTitle)}</strong></div>
          <div class="mhq-modal__body">
            <p style="margin-top:0">Scan the ticket into the input below. Most barcode scanners will type the value and send Enter.</p>
            <input class="mhq-modal__input" type="text" placeholder="${escapeHtml(CONFIG.labels.modalPlaceholder)}" autofocus />
            <div id="mhq-modal-error" style="display:none;color:#b00020;margin-top:10px"></div>
          </div>
          <div class="mhq-modal__footer">
            <button type="button" class="mhq-btn" data-action="cancel">Cancel</button>
            <button type="button" class="mhq-btn mhq-btn--primary" data-action="lookup">Lookup</button>
          </div>
        </div>
      </div>
    `);

    document.body.appendChild(backdrop);

    const input = backdrop.querySelector('.mhq-modal__input');
    const errorEl = backdrop.querySelector('#mhq-modal-error');

    const close = () => backdrop.remove();
    const setError = msg => {
      errorEl.textContent = msg;
      errorEl.style.display = msg ? 'block' : 'none';
    };

    async function submit() {
      const raw = String(input.value || '').trim();
      if (!raw) {
        setError('Scan a ticket first.');
        return;
      }

      const ticketId = raw.replace(/[^0-9A-Za-z\-]/g, '');
      updateBanner(`Looking up ticket ${ticketId}...`);
      setError('');

      try {
        const lifecycle = await fetchLifecycleByTicket(ticketId);
        state.lastTicketId = ticketId;
        state.lastLifecycle = lifecycle;
        const orderData = deriveOrderData(ticketId, lifecycle);
        applyOrderData(orderData);
        close();
      } catch (error) {
        log(error);
        setError(error instanceof Error ? error.message : String(error));
        updateBanner('Lookup failed. Check the scan dialog error.');
      }
    }

    backdrop.addEventListener('click', event => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target === backdrop || target.getAttribute('data-action') === 'cancel') close();
      if (target.getAttribute('data-action') === 'lookup') submit();
    });

    input.addEventListener('keydown', event => {
      if (event.key === 'Enter') {
        event.preventDefault();
        submit();
      }
      if (event.key === 'Escape') close();
    });

    setTimeout(() => input.focus(), 0);
  }

  function injectBarcodeTab() {
    if (qs('#mhq-single-request-barcode-tab')) return true;

    const singleRequestTab = qs(CONFIG.selectors.singleRequestTab);
    if (!singleRequestTab || !singleRequestTab.parentElement) return false;

    const barcodeTab = createElement(`
      <div id="mhq-single-request-barcode-tab" class="mhq-barcode-tab" tabindex="0" role="button" aria-label="Single Request Barcode-tab">
        <div class="mhq-barcode-tab__text">${escapeHtml(CONFIG.labels.newTab)}</div>
      </div>
    `);

    barcodeTab.addEventListener('click', activateBarcodeTab);
    barcodeTab.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activateBarcodeTab();
      }
    });

    singleRequestTab.addEventListener('click', () => {
      setTimeout(activateNormalTab, 0);
    });

    singleRequestTab.parentElement.appendChild(barcodeTab);
    ensureBanner();
    updateBanner('Normal Single Request mode active.');
    log('Injected barcode tab');
    return true;
  }

  function isDeliverySingleRequestPage() {
    return !!qs(CONFIG.selectors.singleRequestTab) && !!getInput('referenceNumber') && document.body.innerText.includes('Delivery Service Request');
  }

  async function mount() {
    if (state.mounted) return;
    for (let i = 0; i < 40; i++) {
      if (isDeliverySingleRequestPage()) {
        injectBarcodeTab();
        state.mounted = true;
        return;
      }
      await wait(500);
    }
  }

  const observer = new MutationObserver(() => {
    if (isDeliverySingleRequestPage() && !qs('#mhq-single-request-barcode-tab')) {
      injectBarcodeTab();
    }
  });

  mount();
  observer.observe(document.documentElement, { childList: true, subtree: true });
})();
